# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# hemligheter – får ALDRIG checkas in
/Key/
*.key
secrets/

# lokala, maskinspecifika Claude-inställningar
.claude/settings.local.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# workflow kräver 'workflow'-scope på token – aktivera enligt README
.github/workflows/
