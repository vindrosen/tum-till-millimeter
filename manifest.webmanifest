{"name":"Tum till Millimeter","short_name":"Tum→mm","description":"Sveriges enkla guide för virkesdimensioner, tum-mått och byggspråk. Omvandla tum till millimeter, se vad 2x4 blir i mm, jämför hyvlat och ohyvlat och slå upp spiklängder, rördimensioner och snickarord.","start_url":"/tum-till-millimeter/","scope":"/tum-till-millimeter/","display":"standalone","orientation":"portrait","background_color":"#f6f1e8","theme_color":"#1c7a43","lang":"sv-SE","categories":["utilities","reference","productivity"],"icons":[{"src":"/tum-till-millimeter/icons/icon-192.png","sizes":"192x192","type":"image/png","purpose":"any"},{"src":"/tum-till-millimeter/icons/icon-512.png","sizes":"512x512","type":"image/png","purpose":"any"},{"src":"/tum-till-millimeter/icons/maskable-192.png","sizes":"192x192","type":"image/png","purpose":"maskable"},{"src":"/tum-till-millimeter/icons/maskable-512.png","sizes":"512x512","type":"image/png","purpose":"maskable"}]}